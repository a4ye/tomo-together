# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# signing
.keystore-pass.txt

# live credentials — never commit
somevariables.txt
infra/*.tfvars

# terraform
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.*
infra/.terraform.lock.hcl.tmp
infra/crash.log

# generated native folders
/ios
/android

# local server state (db + user photos): never commit
server/data/

# build artifact, served by CI instead
tomo-yard.apk
src/.Rhistory
