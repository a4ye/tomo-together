# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.pfx
*.key
*.mobileprovision
*.[Pp]ublish[Ss]ettings

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local environment files and direnv state
.env
.env.*
.envrc
.direnv/
# Templates are intentionally safe to track.
!.env.example
!**/.env.example

# typescript
*.tsbuildinfo

# signing
.keystore-pass.txt

# live credentials — never commit
somevariables.txt
[Aa][Uu][Tt][Hh]0.txt

# terraform
**/.terraform/
*.tfvars
*.tfvars.json
*.tfstate
*.tfstate.*
*.tfplan
tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
.terraform.lock.hcl.tmp
# Sanitized examples may be committed deliberately.
!*.tfvars.example
!*.tfvars.json.example

# generated native folders
/ios
/android

# local server state (db + user photos): never commit
server/data/

# build artifact, served by CI instead
tomo-yard.apk
src/.Rhistory
