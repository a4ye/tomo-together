{
  "name": "unifold-demo-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "check": "node --env-file-if-exists=.env --import tsx scripts/check.ts",
    "setup:webhook": "node --env-file-if-exists=.env --import tsx scripts/setup-webhook.ts",
    "pretest": "rm -rf .data-test",
    "test": "node --env-file=test/.env.test --import tsx --test test/backend.test.ts"
  },
  "dependencies": {
    "@unifold/node": "*",
    "express": "^4.19.2",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
