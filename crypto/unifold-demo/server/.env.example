PORT=8787

# Durable ledger backend. Production accepts only "mongodb" and exits before
# listening if Atlas cannot be initialized. See README.md for Atlas setup.
CRYPTO_STORE_BACKEND=mongodb
MONGODB_URI=mongodb+srv://replace_user:replace_password@replace_cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=ht6_crypto

# Local/test-only JSON fallback (never use in production):
# CRYPTO_STORE_BACKEND=json
# DATA_DIR=./data

# Secret LIVE key (dashboard Test Mode OFF)
UNIFOLD_SECRET_KEY=sk_live_replace_me
# Public key from the same Unifold environment. The current server keeps this
# deployment setting for parity with production even though it is not read yet.
UNIFOLD_PUBLISHABLE_KEY=pk_live_replace_me
# Treasury account holding your USDC on Base
TREASURY_ACCOUNT_ID=ta_replace_me
# Generate a strong value, for example: openssl rand -hex 32
# Set this same server-side value on the main API; never put it in the mobile app.
CRYPTO_SERVICE_TOKEN=replace_me
TREASURY_SOURCE_CHAIN_ID=8453

# Optional: signing secret from your Unifold webhook endpoint (whsec_…). When set,
# POST /webhooks/unifold verifies + processes real-time events (deposit + payout),
# replacing the poll. Needs a public URL (cloudflared/ngrok) to the backend.
# UNIFOLD_WEBHOOK_SECRET=whsec_replace_me

# Net-settlement (optional; USDC base units). Winnings accrue in the ledger and
# only settle on-chain past the threshold — batches transfers to cut fees.
# CREDIT_LIMIT_UNITS=0              # balance floor (0 = no debt; a negative value would allow credit)
# CASHOUT_THRESHOLD_UNITS=20000000  # $20 wallet-ready threshold and withdrawal minimum

# Dangerous production opt-ins. All three are OFF when omitted; only the exact value
# "true" enables them. Review the real-money implications in README.md first.
# ENABLE_RECURRING_REAL_USDC_GRANTS=true
# ENABLE_RAW_BALANCE_ADJUSTMENTS=true
# ENABLE_TREASURY_FUNDED_EVENT_BONUSES=true
