PORT=8787
# Secret LIVE key (dashboard Test Mode OFF)
UNIFOLD_SECRET_KEY=sk_live_replace_me
# Treasury account holding your USDC on Base
TREASURY_ACCOUNT_ID=ta_replace_me
TREASURY_SOURCE_CHAIN_ID=8453

# Optional: signing secret from your Unifold webhook endpoint (whsec_…). When set,
# POST /webhooks/unifold verifies + processes real-time events (deposit + payout),
# replacing the poll. Needs a public URL (cloudflared/ngrok) to the backend.
# UNIFOLD_WEBHOOK_SECRET=whsec_replace_me

# Net-settlement (optional; USDC base units). Winnings accrue in the ledger and
# only settle on-chain past the threshold — batches transfers to cut fees.
# CREDIT_LIMIT_UNITS=0              # balance floor (0 = no debt; a negative value would allow credit)
# CASHOUT_THRESHOLD_UNITS=20000000  # "ready to cash out" once you're owed $20+
